mixin sectionHeading(title, iconType, leadText)
  .section-heading
    .section-heading__inner
      if iconType === 'work'
        img.section-heading__icon.section-heading__icon--work(src="/assets/images/icons/work.svg" alt="" aria-hidden="true")
      else if iconType === 'projects'
        img.section-heading__icon.section-heading__icon--projects(src="/assets/images/icons/projects.svg" alt="" aria-hidden="true")
      else if iconType === 'writing'
        img.section-heading__icon.section-heading__icon--writing(src="/assets/images/icons/writing.svg" alt="" aria-hidden="true")
      h2=title
    if leadText
      p.section-heading__lead=leadText
