mixin socialLinks()
  div.social-links
    a.button.button--large(href="mailto:mike@mcarter.me" aria-label="Email")
      img.button__icon(src="/assets/images/icons/email.svg" alt="")
      span.button__label Email
    a.button.button--large(href="https://www.linkedin.com/in/mike-carter-097b9855/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn")
      img.button__icon(src="/assets/images/icons/linkedin.svg" alt="")
      span.button__label LinkedIn
    a.button.button--large(href="https://x.com/mcarterj" target="_blank" rel="noopener noreferrer" aria-label="X")
      img.button__icon(src="/assets/images/icons/x.svg" alt="")
      span.button__label X
